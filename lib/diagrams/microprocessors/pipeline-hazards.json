    {
      "id": "structural-box",
      "label": "Structural Hazard",
      "x": 10, "y": 595, "width": 275, "height": 210,
      "color": "#FEE2E2", "borderColor": "#DC2626",
      "sublabels": [
        "Cause: Two instructions need the same hardware resource simultaneously.",
        "Example: Single unified memory — IF stage and MEM stage both need memory access at the same time.",
        "Solution: Harvard architecture — use separate Instruction Cache (I-Cache) and Data Cache (D-Cache).",
        "Alternative: Stall the pipeline for 1 cycle by inserting a NOP bubble."
      ],
      "labelSize": 14
    },
    {
      "id": "data-box",
      "label": "Data Hazard (RAW / WAR / WAW)",
      "x": 302, "y": 595, "width": 296, "height": 210,
      "color": "#FEF9C3", "borderColor": "#CA8A04",
      "sublabels": [
        "RAW (Read After Write): I2 reads register before I1 finishes writing it. Most common hazard type.",
        "Example: ADD R1,R2,R3 → SUB R4,R1,R5 — R1 not ready when SUB needs it.",
        "WAR (Write After Read): I2 writes a reg before I1 reads it. Rare in in-order pipelines.",
        "WAW (Write After Write): I2 writes same register as I1 — output dependency.",
        "Solutions: (1) Stall/NOP bubbles, (2) Data Forwarding/Bypassing — route result from EX output directly to EX input."
      ],
      "labelSize": 13
    },
    {
      "id": "control-box",
      "label": "Control Hazard (Branch Hazard)",
      "x": 615, "y": 595, "width": 275, "height": 210,
      "color": "#DBEAFE", "borderColor": "#2563EB",
      "sublabels": [
        "Cause: Branch instruction changes PC. Instructions already fetched after the branch may be from the wrong path.",
        "Example: BEQ instruction — branch outcome is known only in EX stage (cycle 3).",
        "Penalty: 2 instructions already fetched must be flushed (wasted cycles).",
        "Solutions: (1) Branch Prediction — static or dynamic, (2) Delayed branching — execute next instruction always, (3) Flush wrong-path instructions."
      ],
      "labelSize": 13
    }
  ],
