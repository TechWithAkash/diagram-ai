# Groq API Key (primary - ultra cheap, ~$0.05/M tokens)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (fallback - free tier available)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Primary model - cheapest, fastest
GROQ_MODEL=llama-3.1-8b-instant

# Fallback model for complex diagrams
GROQ_MODEL_PRO=llama-3.3-70b-versatile

NEXT_PUBLIC_APP_NAME=DiagramAI
NEXT_PUBLIC_APP_URL=http://localhost:3000
